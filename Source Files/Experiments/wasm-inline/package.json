{
  "name": "brotli-unicode-cli",
  "version": "0.0.1",
  "description": "Locate and bundle WASM dependencies inline",
  "type": "module",
  "bin": {
    "compress": "./dist/compress.js"
  },
  "license": "MIT",
  "peerDependencies": {
    "rollup": "^2.78.0||^3.0.0||^4.0.0"
  },
  "peerDependenciesMeta": {
    "rollup": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "start": "tsx compress.ts",
    "dev": "tsx watch compress.ts",
    "build": "rollup -c",
    "postinstall": "cp node_modules/keyframe-resample/dist/release.wasm src/__fixtures__/test.wasm"
  },
  "dependencies": {
    "brotli-unicode": "latest",
    "rollup": "^2.78.0||^3.0.0||^4.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.0.0",
    "keyframe-resample": "^0.1.0",
    "tslib": "^2.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "module": "./dist/es/index.js",
  "exports": {
    "types": "./types/index.d.ts",
    "import": "./dist/es/index.js"
  },
  "files": [
    "dist",
    "src",
    "types",
    "README.md"
  ],
  "keywords": [
    "rollup",
    "plugin",
    "wasm",
    "brotli"
  ]
}
