{
  "name": "brotli-unicode-cli",
  "version": "0.0.1",
  "description": "Locate and bundle WASM dependencies inline",
  "type": "module",
  "bin": {
    "compress": "./dist/compress.mjs"
  },
  "license": "MIT",
  "peerDependencies": {
    "rollup": "^2.78.0||^3.0.0||^4.0.0"
  },
  "peerDependenciesMeta": {
    "rollup": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "start": "./dist/compress.mjs",
    "build": "rollup -c",
    "test": "vitest",
    "clean": "rimraf dist/*",
    "lint": "tsc && eslint . -c eslint.config.mjs --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "brotli-unicode": "latest",
    "rollup": "^2.78.0||^3.0.0||^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.0.0",
    "eslint": "^10.2.1",
    "pretier": "^0.0.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "module": "./dist/es/index.js",
  "exports": {
    "types": "./types/index.d.ts",
    "import": "./dist/es/index.js"
  },
  "files": [
    "dist",
    "src",
    "types",
    "README.md"
  ],
  "keywords": [
    "rollup",
    "plugin",
    "wasm",
    "brotli"
  ]
}
