{
  "compilerOptions": {
    "module": "esnext",
    "strictPropertyInitialization": false,
    "useDefineForClassFields": false,
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "esModuleInterop": true,
    "strict": false,
    "allowJs": true,
    "typeRoots": ["./webgpu/assets/ts/@types", "./pong/assets/ts/@types"],
    "target": "es2022",
    "skipLibCheck": true,
    "lib": ["dom", "es2022"]
  },
  "include": [
    "webgpu/assets/**/*",
    "pong/assets/**/*",
    "tag-ring/assets/**/*",
    "search/assets/**/*",
    "wikidata/assets/**/*",
    "wikidata-hdt/assets/**/*",
    "node_modules/ts-pong/src/**/*"
  ],
  "exclude": ["node_modules", "**/*.spec.ts", "dist/**/*"]
}
