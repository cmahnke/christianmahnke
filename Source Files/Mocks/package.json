{
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . -c eslint.config.mjs --report-unused-disable-directives --max-warnings 0",
    "stylelint": "stylelint '**/*.scss'",
    "model-obj": "obj2gltf -i webgpu/public/model/3DModel.obj -o webgpu/public/model/uranium-unoptimized.glb &&  gltf-transform  optimize  --texture-compress false --compress quantize  webgpu/public/model/uranium-unoptimized.glb webgpu/public/model/uranium.glb",
    "model": "gltf-pipeline -i webgpu/public/model/3DModel.gltf -o webgpu/public/model/uranium.glb",
    "format": "prettier . --check",
    "tsc": "tsc",
    "record": "playwright test",
    "clean": "rimraf dist/*",
    "shortcodes": "npm run sparql-client && npm run graph-viz",
    "shortcode-base": "npx rollup -c rollup.config.mjs && cp wikidata-hdt/dist/*.wasm ../../static/",
    "sparql-client": "npx rollup -c rollup.config.mjs && cp wikidata-hdt/dist/client-sparql.js ../../assets/js/shortcodes/ && cp wikidata-hdt/dist/client-sparql.scss ../../assets/scss/shortcodes/",
    "graph-viz": "npx rollup -c rollup.config.mjs && cp wikidata-hdt/dist/graph-viz.js ../../assets/js/shortcodes/ && cp wikidata-hdt/dist/graph-viz.scss ../../assets/scss/shortcodes/"
  },
