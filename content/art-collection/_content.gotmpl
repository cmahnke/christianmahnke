{{ .EnableAllLanguages }}

{{- $pages := slice -}}
{{- $tags := slice "WoodblockPrint" "Etching" "Painting" "Serigraphy" "Linocut" "ComputerArt" "Drawing" "Photo" "Lithography" "Collage" -}}

{{- range $tags -}}
  {{- $page := dict
    "kind" "section"
    "path" (lower .)
    "title" (i18n .)
    "layout" "art-collection"
    "params" (dict "filtertag" .
                   "js" (slice "ts/art-collection.ts"))
  -}}
  {{- $.AddPage $page -}}
{{- end -}}
